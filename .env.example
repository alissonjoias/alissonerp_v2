# ===========================================================================
#  ERP Alisson Joias v2 — Variáveis de ambiente
#  Aponta para o Supabase que contém o schema `alissonerp` (banco do legado).
#  NUNCA use o banco de produção do legado para desenvolvimento.
# ===========================================================================
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...     # anon (pública — a segurança vem das RLS policies)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...         # service_role — SÓ scripts/servidor, NUNCA no client

# Connection string usada SOMENTE por scripts de migração (npm run db:push)
# Supabase > Project Settings > Database > Connection string > URI (modo "Session")
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxx.supabase.co:5432/postgres
